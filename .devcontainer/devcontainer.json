{
    "build": {
        "dockerfile": "Dockerfile",
        "options": [
            "--secret",
            "id=gitlab_key,src=${localEnv:DEV_CON_HOME}/ssh/gitlab-niilz"
        ],
        "args": {
            "BASE_IMAGE": "mcr.microsoft.com/devcontainers/rust:latest"
        }
    },
    "forwardPorts": [
        2222
    ],
    "features": {
        "ghcr.io/w3cj/devcontainer-features/firewall:latest": {
            "verbose": true,
            "hosts": "lh3.googleusercontent.com",
            "googleAiApi": true,
            "dnsPublic": true
        },
        "ghcr.io/devcontainers/features/common-utils:2": {},
        "ghcr.io/aqua/devcontainer-antigravity-cli/antigravity-cli:1": {},
        "ghcr.io/devcontainers/features/sshd:1": {},
        "ghcr.io/devcontainers/features/docker-in-docker:4": {
            "moby": "false"
        },
        "ghcr.io/devcontainers/features/node:2": {
            "pnpmVersion": "latest",
            "nodeGypDependencies": true
        },
        "ghcr.io/jsburckhardt/devcontainer-features/fd:1": {},
        "ghcr.io/jsburckhardt/devcontainer-features/ripgrep:1": {}
    },
    "containerEnv": {
        "TERM": "xterm-256color",
        "COLORTERM": "truecolor"
    },
    "mounts": [
        "source=${localWorkspaceFolder}/.gemini,target=/home/vscode/.gemini,type=bind,consistency=cached"
    ],
    // Change shell, permanently destroy sudo privileges, then configure environment
    "postCreateCommand": "sudo chsh -s /usr/bin/fish vscode && sudo rm -f /etc/sudoers.d/vscode && dotbot -c /opt/dotbot.yaml -d /opt/dev-configs"
}
