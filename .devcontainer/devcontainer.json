{
    "build": {
        "dockerfile": "Dockerfile",
        "options": [
            "--secret", "id=gitlab_key,src=${localEnv:DEV_CON_HOME}/ssh/gitlab-niilz"
        ],
        "args": {
            "BASE_IMAGE": "mcr.microsoft.com/devcontainers/rust:latest"
        }
    },
    "forwardPorts": [
        2222
    ],
    "features": {
        "ghcr.io/devcontainer-community/devcontainer-features/neovim.io:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": {},
        "ghcr.io/aqua/devcontainer-antigravity-cli/antigravity-cli:1": {},
        "ghcr.io/devcontainers/features/sshd:1": {},
        "ghcr.io/devcontainers/features/docker-in-docker:4": {
            "moby": "false"
        }
    },
    "containerEnv": {
        "TERM": "xterm-256color",
        "COLORTERM": "truecolor"
    },
    // Set fish as default shell, then run dotbot
    "postCreateCommand": "sudo chsh -s /usr/bin/fish vscode && dotbot -c /opt/dotbot.yaml -d /opt/dev-configs"
}