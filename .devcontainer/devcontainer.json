{
    "image": "mcr.microsoft.com/devcontainers/rust",
    "features": {
        "ghcr.io/devcontainer-community/devcontainer-features/neovim.io:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": {},
        "ghcr.io/aqua/devcontainer-antigravity-cli/antigravity-cli:1": {},
        "ghcr.io/devcontainers/features/sshd:1": {},
        "ghcr.io/devcontainers/features/docker-in-docker:4": {
            "moby": "false"
        }
    },
    // Pre-create host directories and the environment file to ensure proper ownership and avoid startup failures
    "initializeCommand": "mkdir -p ~/DEV/devcontainers/gemini ~/DEV/devcontainers/ssh ~/DEV/devcontainers/docker && [ -f ~/DEV/devcontainers/devcontainer.env ] || (echo 'DEVCONTAINER_PASSWORD=' && echo 'DEVCONTAINER_PASSWORD_HASH=') > ~/DEV/devcontainers/devcontainer.env",
    // Bind-mount host-side directories under ~/DEV/devcontainers to persist configurations
    "mounts": [
-       "source=${localEnv:HOME}/DEV/devcontainers/ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
        "source=${localEnv:HOME}/DEV/devcontainers/gemini,target=/home/vscode/.gemini,type=bind,consistency=cached",
        "source=${localEnv:HOME}/DEV/devcontainers/devcontainer.env,target=/tmp/devcontainer.env,type=bind,readonly"
    ],
    // Set the password on container startup if provided via host environment variables
    "postStartCommand": "if [ -f /tmp/devcontainer.env ]; then . /tmp/devcontainer.env; if [ -n \"$DEVCONTAINER_PASSWORD_HASH\" ]; then sudo usermod --password \"$DEVCONTAINER_PASSWORD_HASH\" $(whoami); elif [ -n \"$DEVCONTAINER_PASSWORD\" ]; then echo \"$(whoami):$DEVCONTAINER_PASSWORD\" | sudo chpasswd; fi; fi"
}